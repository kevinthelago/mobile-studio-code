{
  "expo": {
    "name": "base-studio-code",
    "slug": "mobile-studio-code",
    "owner": "kevinthelago",
    "version": "1.0.0",
    "icon": "./src/assets/icon-ios.png",
    "orientation": "portrait",
    "scheme": "mobilestudiocode",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b0d14",
    "newArchEnabled": true,
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/a11a7b6c-6d05-4b39-9ff1-ea694b914b66"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mobilestudiocode.app",
      "backgroundColor": "#0b0d14",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Choose screenshots or images to send to Claude.",
        "NSCameraUsageDescription": "Scan a QR code to pair with base-studio-code.",
        "NSLocalNetworkUsageDescription": "Connect to base-studio-code running on your local network to mirror its console sessions.",
        "UIUserInterfaceStyle": "Dark",
        "UIBackgroundModes": ["remote-notification"],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/source.png",
        "backgroundColor": "#0b0d14"
      },
      "backgroundColor": "#0b0d14",
      "package": "com.mobilestudiocode.app"
    },
    "plugins": [
      "./plugins/withFirebasePodfile",
      "expo-router",
      "expo-secure-store",
      "expo-updates",
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose screenshots or images to send to Claude."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Scan a QR code to pair with base-studio-code."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "extra": {
      "eas": {
        "projectId": "a11a7b6c-6d05-4b39-9ff1-ea694b914b66"
      }
    }
  }
}

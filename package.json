{
  "name": "mobile-studio-code",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "update": "eas update --branch main",
    "update:preview": "eas update --branch preview",
    "build:preview": "eas build --platform ios --profile preview",
    "build:dev": "eas build --platform ios --profile development",
    "build:prod": "eas build --platform ios --profile production",
    "submit": "eas submit --platform ios --profile production",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\""
  },

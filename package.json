    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "expo": "~54.0.35",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
